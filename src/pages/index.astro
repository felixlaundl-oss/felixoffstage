---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, 3);
---

<Layout title="Felix Off Stage — Art & Theater">
  <style>
    .hero {
      text-align: center;
      padding: 5rem 0 4rem;
      border-bottom: 1px solid var(--gray-light);
      margin-bottom: 4rem;
    }
    .hero-label {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--burgund);
      margin-bottom: 1.5rem;
      font-weight: 500;
    }
    .hero h1 {
      font-size: clamp(2.8rem, 6vw, 4.5rem);
      color: var(--black);
      margin-bottom: 1.2rem;
      line-height: 1.1;
    }
    .hero-sub {
      font-size: 1rem;
      color: var(--gray);
      font-style: italic;
      font-family: 'Playfair Display', serif;
      margin-bottom: 2.5rem;
    }
    .burgund-line {
      width: 48px;
      height: 1.5px;
      background: var(--burgund);
      margin: 0 auto 2.5rem;
    }

    /* Email signup */
    .signup {
      display: flex;
      gap: 0;
      max-width: 420px;
      margin: 0 auto;
    }
    .signup input {
      flex: 1;
      padding: 0.75rem 1rem;
      border: 1px solid var(--gray-light);
      border-right: none;
      background: white;
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      color: var(--black);
      outline: none;
    }
    .signup input::placeholder { color: #aaa; }
    .signup button {
      padding: 0.75rem 1.4rem;
      background: var(--burgund);
      color: white;
      border: none;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      font-weight: 500;
      transition: background 0.2s;
    }
    .signup button:hover { background: #8B2020; }

    /* Recent posts */
    .section-label {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--burgund);
      margin-bottom: 2rem;
      font-weight: 500;
    }
    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }
    .post-card {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--gray-light);
      background: white;
      transition: border-color 0.2s;
    }
    .post-card:hover { border-color: var(--burgund); }
    .post-card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
    }
    .post-card-placeholder {
      width: 100%;
      height: 180px;
      background: #f0ebe4;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .post-card-placeholder svg { opacity: 0.15; }
    .post-card-body { padding: 1.2rem; flex: 1; }
    .post-tag {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--burgund);
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    .post-card h3 {
      font-size: 1.05rem;
      margin-bottom: 0.5rem;
      line-height: 1.3;
      color: var(--black);
    }
    .post-card p {
      font-size: 0.82rem;
      color: var(--gray);
      line-height: 1.6;
    }
    .all-posts {
      text-align: center;
      margin-top: 1rem;
    }
    .all-posts a {
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--burgund);
      border-bottom: 1px solid var(--burgund);
      padding-bottom: 2px;
      font-weight: 500;
      transition: opacity 0.2s;
    }
    .all-posts a:hover { opacity: 0.7; }
  </style>

  <!-- Hero -->
  <section class="hero">
    <p class="hero-label">Art & Theater</p>
    <h1>Felix Off Stage</h1>
    <p class="hero-sub">Essays and criticism from the wings of European theater.</p>
    <div class="burgund-line"></div>
    <form class="signup" action="https://app.us1.list-manage.com/subscribe/post" method="POST">
      <input type="email" name="EMAIL" placeholder="Your email address" required />
      <button type="submit">Subscribe</button>
    </form>
  </section>

  <!-- Recent Posts -->
  <section>
    <p class="section-label">Recent Essays</p>
    <div class="posts-grid">
      {recentPosts.length === 0 ? (
        <p style="color: var(--gray); font-style: italic;">Erste Essays erscheinen bald.</p>
      ) : (
        recentPosts.map((post) => (
          <a href={`/posts/${post.id}/`} class="post-card">
            {post.data.ogImage ? (
              <img src={typeof post.data.ogImage === "string" ? post.data.ogImage : ""} alt={post.data.title} />
            ) : (
              <div class="post-card-placeholder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6B1A1A" stroke-width="1">
                  <rect x="3" y="3" width="18" height="18" rx="1"/>
                  <path d="M3 9h18M9 21V9"/>
                </svg>
              </div>
            )}
            <div class="post-card-body">
              {post.data.tags?.[0] && <p class="post-tag">{post.data.tags[0]}</p>}
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))
      )}
    </div>
    <div class="all-posts">
      <a href="/blog">All Essays →</a>
    </div>
  </section>
</Layout>
