---

<Layout title="Resources — Felix Off Stage">
  <style>
    .resources-header {
      background: var(--cream);
      text-align: center;
      padding: 4rem 3rem 3rem;
      border-bottom: 1px solid rgba(107,26,26,0.15);
    }
    .resources-label { font-size: 0.68rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--burgund); margin-bottom: 1rem; font-weight: 500; }
    .resources-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; color: var(--black); }
    .resources-header p { color: var(--gray); font-style: italic; font-family: 'Playfair Display', serif; }
    .burgund-line { width: 40px; height: 1.5px; background: var(--burgund); margin: 1.5rem auto 0; }

    .resources-body { background: var(--cream); padding: 4rem 0 6rem; }
    .resources-inner { max-width: 1200px; margin: 0 auto; padding: 0 3rem; }

    .section-title { font-size: 0.68rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--burgund); margin-bottom: 2rem; font-weight: 500; padding-bottom: 0.8rem; border-bottom: 1px solid rgba(107,26,26,0.15); }

    .cards { display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 5rem; }

    .card {
      display: grid;
      grid-template-columns: 280px 1fr;
      background: var(--white);
      border-left: 2px solid var(--burgund);
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      text-decoration: none;
      color: inherit;
      transition: box-shadow 0.3s, transform 0.3s;
    }
    .card:hover { box-shadow: 0 6px 28px rgba(0,0,0,0.12); transform: translateY(-3px); }
    .card img { width: 280px; height: 200px; object-fit: cover; display: block; }
    .card-body { padding: 1.8rem 2rem; display: flex; flex-direction: column; justify-content: center; }
    .card-tag { font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--burgund); margin-bottom: 0.6rem; font-weight: 500; }
    .card-body h2 { font-size: 1.3rem; margin-bottom: 0.7rem; line-height: 1.3; color: var(--black); }
    .card-body p { font-size: 0.85rem; color: var(--gray); line-height: 1.75; margin-bottom: 1rem; }
    .card-link { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--burgund); border-bottom: 1px solid var(--burgund); padding-bottom: 1px; align-self: flex-start; font-weight: 500; transition: opacity 0.2s; }
    .card-link:hover { opacity: 0.7; }

    @media (max-width: 768px) {
      .card { grid-template-columns: 1fr; }
      .card img { width: 100%; height: 200px; }
      .resources-inner { padding: 0 1.5rem; }
      .resources-header { padding: 3rem 1.5rem 2rem; }
    }
  </style>

  <div class="resources-header">
    <p class="resources-label">Kuratiert</p>
    <h1>Resources</h1>
    <p>Spielpläne, Empfehlungen und Lesestoff für Theaterliebhaber.</p>
    <div class="burgund-line"></div>
  </div>

  <div class="resources-body">
    <div class="resources-inner">
      <p class="section-title">Theaterhäuser</p>
      <div class="cards">
        {currentSeason.map(item => (
          <a href={item.link} target="_blank" rel="noopener" class="card">
            <img src={item.image} alt={item.title} />
            <div class="card-body">
              <p class="card-tag">{item.tag}</p>
              <h2>{item.title}</h2>
              <p>{item.description}</p>
              <span class="card-link">Zum Spielplan →</span>
            </div>
          </a>
        ))}
      </div>

      <p class="section-title">Empfehlungen</p>
      <div class="cards">
        {recommendations.map(item => (
          <a href={item.link} target="_blank" rel="noopener" class="card">
            <img src={item.image} alt={item.title} />
            <div class="card-body">
              <p class="card-tag">{item.tag}</p>
              <h2>{item.title}</h2>
              <p>{item.description}</p>
              <span class="card-link">Entdecken →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
