---

<Layout title="Resources — Felix Off Stage">
  <style>
    .resources-header {
      text-align: center;
      padding: 3rem 0 2.5rem;
      border-bottom: 1px solid var(--gray-light);
      margin-bottom: 4rem;
    }
    .resources-label {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--burgund);
      margin-bottom: 1rem;
      font-weight: 500;
    }
    .resources-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .resources-header p {
      color: var(--gray);
      font-style: italic;
      font-family: 'Playfair Display', serif;
    }
    .burgund-line {
      width: 40px;
      height: 1.5px;
      background: var(--burgund);
      margin: 1.5rem auto 0;
    }
    .section-title {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--burgund);
      margin-bottom: 2rem;
      font-weight: 500;
    }
    .cards { display: flex; flex-direction: column; margin-bottom: 5rem; }
    .card {
      display: grid;
      grid-template-columns: 320px 1fr;
      border: 1px solid var(--gray-light);
      background: white;
      margin-bottom: 2rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .card:hover {
      border-color: var(--burgund);
      box-shadow: 0 4px 24px rgba(107,26,26,0.06);
    }
    .card img {
      width: 320px;
      height: 220px;
      object-fit: cover;
      display: block;
    }
    .card-body {
      padding: 2rem 2.2rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .card-tag {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--burgund);
      margin-bottom: 0.7rem;
      font-weight: 500;
    }
    .card-body h2 {
      font-size: 1.4rem;
      margin-bottom: 0.8rem;
      line-height: 1.3;
      color: var(--black);
    }
    .card-body p {
      font-size: 0.88rem;
      color: var(--gray);
      line-height: 1.75;
      margin-bottom: 1.2rem;
    }
    .card-link {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--burgund);
      border-bottom: 1px solid var(--burgund);
      padding-bottom: 1px;
      align-self: flex-start;
      font-weight: 500;
    }
    @media (max-width: 680px) {
      .card { grid-template-columns: 1fr; }
      .card img { width: 100%; height: 200px; }
    }
  </style>

  <div class="resources-header">
    <p class="resources-label">Kuratiert</p>
    <h1>Resources</h1>
    <p>Spielpläne, Empfehlungen und Lesestoff für Theaterliebhaber.</p>
    <div class="burgund-line"></div>
  </div>

  <p class="section-title">Wien — Aktuelle Saison</p>
  <div class="cards">
    {currentSeason.map(item => (
      <a href={item.link} target="_blank" rel="noopener" class="card">
        <img src={item.image} alt={item.title} />
        <div class="card-body">
          <p class="card-tag">{item.tag}</p>
          <h2>{item.title}</h2>
          <p>{item.description}</p>
          <span class="card-link">Zum Spielplan →</span>
        </div>
      </a>
    ))}
  </div>

  <p class="section-title">Empfehlungen</p>
  <div class="cards">
    {recommendations.map(item => (
      <a href={item.link} target="_blank" rel="noopener" class="card">
        <img src={item.image} alt={item.title} />
        <div class="card-body">
          <p class="card-tag">{item.tag}</p>
          <h2>{item.title}</h2>
          <p>{item.description}</p>
          <span class="card-link">Entdecken →</span>
        </div>
      </a>
    ))}
  </div>
</Layout>
