---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;
const { title, description, ogImage, pubDatetime, tags } = post.data;
const { Content } = await render(post);

const ogImageUrl = typeof ogImage === "string" ? ogImage : undefined;

const sortedPosts = getSortedPosts(posts);
const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
---

<Layout title={`${title} — Felix Off Stage`} description={description}>
  <style>
    .post-wrap {
      max-width: 680px;
      margin: 0 auto;
      padding: 3rem 2rem 5rem;
    }

    /* Back link */
    .back {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray);
      margin-bottom: 2.5rem;
      transition: color 0.2s;
    }
    .back:hover { color: var(--burgund); }

    /* Cover image */
    .cover {
      width: 100%;
      height: 400px;
      object-fit: cover;
      margin-bottom: 2.5rem;
    }

    /* Meta */
    .post-meta {
      margin-bottom: 2rem;
    }
    .post-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 0.8rem;
    }
    .post-tag {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--burgund);
      font-weight: 500;
    }
    .post-tag::after { content: "·"; margin-left: 0.5rem; color: var(--gray-light); }
    .post-tag:last-child::after { content: ""; }

    .post-title {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      line-height: 1.2;
      margin-bottom: 0.8rem;
      color: var(--black);
    }
    .post-description {
      font-size: 1rem;
      color: var(--gray);
      font-style: italic;
      font-family: 'Playfair Display', serif;
      margin-bottom: 0.8rem;
      line-height: 1.6;
    }
    .post-date {
      font-size: 0.75rem;
      color: #aaa;
      letter-spacing: 0.08em;
    }
    .burgund-line {
      width: 40px;
      height: 1.5px;
      background: var(--burgund);
      margin: 1.5rem 0 2.5rem;
    }

    /* Article content */
    .prose {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      line-height: 1.9;
      color: #333;
    }
    .prose p { margin-bottom: 1.5rem; }
    .prose h2 {
      font-size: 1.3rem;
      margin: 2.5rem 0 1rem;
      color: var(--black);
      font-weight: 500;
    }
    .prose h3 {
      font-size: 1.1rem;
      margin: 2rem 0 0.8rem;
      color: var(--black);
    }
    .prose strong { font-weight: 500; color: var(--black); }
    .prose em { font-style: italic; }
    .prose hr {
      border: none;
      border-top: 1px solid var(--gray-light);
      margin: 2rem 0;
    }
    .prose blockquote {
      border-left: 2px solid var(--burgund);
      padding-left: 1.2rem;
      margin: 1.5rem 0;
      color: var(--gray);
      font-style: italic;
    }

    /* Contact CTA */
    .contact-cta {
      margin-top: 4rem;
      padding: 2rem;
      border: 1px solid var(--gray-light);
      background: white;
      text-align: center;
    }
    .contact-cta p {
      font-size: 0.85rem;
      color: var(--gray);
      font-style: italic;
      font-family: 'Playfair Display', serif;
      margin-bottom: 1rem;
    }
    .contact-cta a {
      display: inline-block;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: white;
      background: var(--burgund);
      padding: 0.7rem 1.8rem;
      font-weight: 500;
      transition: background 0.2s;
    }
    .contact-cta a:hover { background: #8B2020; color: white; }

    /* Prev/Next */
    .post-nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--gray-light);
    }
    .post-nav a {
      font-size: 0.8rem;
      color: var(--gray);
      transition: color 0.2s;
      line-height: 1.4;
    }
    .post-nav a:hover { color: var(--burgund); }
    .post-nav .nav-label {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--burgund);
      display: block;
      margin-bottom: 0.3rem;
    }
    .post-nav .next { text-align: right; }
  </style>

  <div class="post-wrap">
    <a href="/blog" class="back">← Alle Essays</a>

    {ogImageUrl && <img src={ogImageUrl} alt={title} class="cover" />}

    <div class="post-meta">
      {tags && tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => <span class="post-tag">{tag}</span>)}
        </div>
      )}
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-description">{description}</p>}
      <p class="post-date">
        {pubDatetime?.toLocaleDateString("de-AT", { day: "2-digit", month: "long", year: "numeric" })}
      </p>
    </div>

    <div class="burgund-line"></div>

    <article class="prose">
      <Content />
    </article>

    <!-- Contact CTA -->
    <div class="contact-cta">
      <p>Gedanken zu diesem Essay? Ich freue mich über jede Nachricht.</p>
      <a href="/contact">Schreib mir →</a>
    </div>

    <!-- Prev/Next -->
    {(prevPost || nextPost) && (
      <nav class="post-nav">
        <div>
          {prevPost && (
            <a href={`/posts/${prevPost.id}/`}>
              <span class="nav-label">← Vorheriger</span>
              {prevPost.data.title}
            </a>
          )}
        </div>
        <div class="next">
          {nextPost && (
            <a href={`/posts/${nextPost.id}/`}>
              <span class="nav-label">Nächster →</span>
              {nextPost.data.title}
            </a>
          )}
        </div>
      </nav>
    )}
  </div>
</Layout>
