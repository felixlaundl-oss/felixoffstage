---
type Props = {
  title?: string;
  description?: string;
};
const {
  title = "Felix Off Stage",
  description = "Essays and criticism on European theater.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --navy: #080C14;
        --navy-mid: #0D1526;
        --burgund: #6B1A1A;
        --cream: #F5EFE6;
        --white: #FDFAF6;
        --black: #1a1a1a;
        --gray: #555555;
        --gray-light: #DDD6CE;
        --shadow-sm: 0 2px 12px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 24px rgba(0,0,0,0.12);
        --shadow-lg: 0 8px 40px rgba(0,0,0,0.18);
      }
      html { font-size: 16px; scroll-behavior: smooth; }
      body {
        background: var(--cream);
        color: var(--black);
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        line-height: 1.7;
        min-height: 100vh;
        overflow-x: hidden;
      }
      h1,h2,h3,h4 { font-family: 'Playfair Display', Georgia, serif; font-weight: 400; line-height: 1.2; }
      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; height: auto; display: block; }

      @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
      main { animation: fadeIn 0.45s ease forwards; }

      .greek-strip { width: 100%; height: 18px; overflow: hidden; background: var(--navy); }

      nav {
        background: var(--navy);
        border-bottom: 1px solid rgba(107,26,26,0.5);
        position: sticky;
        top: 0;
        z-index: 100;
        width: 100%;
      }
      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 68px;
      }
      .nav-logo { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: #F0F2F8; }
      .nav-logo span { display: block; font-size: 0.6rem; letter-spacing: 0.2em; color: var(--burgund); font-family: 'Inter', sans-serif; font-weight: 500; text-transform: uppercase; margin-top: 2px; }
      .nav-links { display: flex; gap: 2.5rem; list-style: none; }
      .nav-links a { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: #F0F2F8; position: relative; padding-bottom: 2px; }
      .nav-links a::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 1px; background: var(--burgund); transition: width 0.25s; }
      .nav-links a:hover::after { width: 100%; }
      .nav-toggle { display: none; background: none; border: none; cursor: pointer; color: #F0F2F8; padding: 4px; }

      main { position: relative; width: 100%; }
      .content-wrap { max-width: 1200px; margin: 0 auto; padding: 0 3rem; }

      /* Transition dark to cream */
      .transition-to-cream {
        height: 40px;
        background: linear-gradient(to bottom, #0D1526 0%, #2e2820 40%, #F5EFE6 100%);
      }
      /* Transition cream to dark */
      .transition-to-dark {
        height: 40px;
        background: linear-gradient(to bottom, #FFFFFF 0%, #2e2820 60%, #080C14 100%);
      }

      footer {
        background: var(--navy);
        padding: 3rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #FFFFFF; }
      .footer-copy { font-size: 0.72rem; color: #FFFFFF; letter-spacing: 0.08em; }
      .footer-links { display: flex; gap: 2rem; list-style: none; }
      .footer-links a { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: #FFFFFF; transition: color 0.2s; }
      .footer-links a:hover { color: var(--burgund); }

      @media (max-width: 768px) {
        .nav-inner { padding: 0 1.5rem; }
        .nav-links { display: none; position: absolute; top: 68px; left: 0; right: 0; background: var(--navy); flex-direction: column; padding: 1.5rem 2rem; gap: 1.5rem; border-top: 1px solid rgba(107,26,26,0.4); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
        .nav-links.open { display: flex; }
        .nav-toggle { display: block; }
        .content-wrap { padding: 0 1.5rem; }
        footer { padding: 2rem 1.5rem; flex-direction: column; text-align: center; }
      }
    </style>
  </head>
  <body>
    <div class="greek-strip">
      <svg width="100%" height="18" xmlns="http://www.w3.org/2000/svg">
        <pattern id="g1" x="0" y="0" width="32" height="18" patternUnits="userSpaceOnUse">
          <path d="M0 9 L4 9 L4 4 L12 4 L12 14 L8 14 L8 9 L16 9 L16 0 L24 0 L24 9 L20 9 L20 4 L28 4 L28 14 L32 14" fill="none" stroke="#8B1A1A" stroke-width="1"/>
        </pattern>
        <rect width="100%" height="18" fill="url(#g1)" opacity="0.4"/>
        <line x1="0" y1="17" x2="100%" y2="17" stroke="#6B1A1A" stroke-width="0.5" opacity="0.5"/>
      </svg>
    </div>

    <nav>
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          Felix Off Stage
          <span>Art & Theater</span>
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Menu">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="2" y1="6" x2="20" y2="6"/>
            <line x1="2" y1="11" x2="20" y2="11"/>
            <line x1="2" y1="16" x2="20" y2="16"/>
          </svg>
        </button>
        <ul class="nav-links" id="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
    </nav>

    <main><slot /></main>

    <div class="transition-to-dark"></div>

    <div class="greek-strip" style="transform: scaleY(-1);">
      <svg width="100%" height="18" xmlns="http://www.w3.org/2000/svg">
        <pattern id="g2" x="0" y="0" width="32" height="18" patternUnits="userSpaceOnUse">
          <path d="M0 9 L4 9 L4 4 L12 4 L12 14 L8 14 L8 9 L16 9 L16 0 L24 0 L24 9 L20 9 L20 4 L28 4 L28 14 L32 14" fill="none" stroke="#8B1A1A" stroke-width="1"/>
        </pattern>
        <rect width="100%" height="18" fill="url(#g2)" opacity="0.3"/>
      </svg>
    </div>

    <footer>
      <span class="footer-logo">Felix Off Stage</span>
      <span class="footer-copy">© 2026 · Essays on European Theater</span>
      <ul class="footer-links">
        <li><a href="/blog">Blog</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/impressum">Impressum</a></li>
        <li><a href="/datenschutz">Datenschutz</a></li>
      </ul>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const links = document.getElementById('nav-links');
      toggle?.addEventListener('click', () => links?.classList.toggle('open'));
    </script>
  </body>
</html>
