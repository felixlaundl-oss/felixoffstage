---
import { SITE } from "@/config";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Felix Off Stage",
  description = "Essays and criticism on European theater.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --burgund: #6B1A1A;
        --cream: #FAF7F2;
        --black: #1a1a1a;
        --gray: #666;
        --gray-light: #e0dcd6;
      }
      body {
        background: var(--cream);
        color: var(--black);
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        line-height: 1.7;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }
      h1,h2,h3,h4 { font-family: 'Playfair Display', Georgia, serif; font-weight: 400; }
      a { color: inherit; text-decoration: none; }
      a:hover { color: var(--burgund); }

      /* NAV */
      nav {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 3rem;
        border-bottom: 1px solid var(--gray-light);
      }
      .nav-logo {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        letter-spacing: 0.02em;
        color: var(--black);
      }
      .nav-logo span {
        display: block;
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        color: var(--burgund);
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        text-transform: uppercase;
        margin-top: 2px;
      }
      .nav-links {
        display: flex;
        gap: 2.5rem;
        list-style: none;
      }
      .nav-links a {
        font-size: 0.8rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 400;
        color: var(--gray);
        transition: color 0.2s;
      }
      .nav-links a:hover { color: var(--burgund); }

      /* GREEK ORNAMENT BACKGROUND */
      .greek-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }

      /* MAIN */
      main {
        position: relative;
        z-index: 1;
        max-width: 860px;
        margin: 0 auto;
        padding: 4rem 2rem;
      }

      /* FOOTER */
      footer {
        position: relative;
        z-index: 1;
        border-top: 1px solid var(--gray-light);
        padding: 2rem 3rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        color: var(--gray);
        letter-spacing: 0.06em;
      }
    </style>
  </head>
  <body>
    <!-- Greek architectural background -->
    <div class="greek-bg">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
        <!-- Top border: meander/greek key pattern -->
        <pattern id="meander" x="0" y="0" width="40" height="20" patternUnits="userSpaceOnUse">
          <path d="M0 10 L5 10 L5 5 L15 5 L15 15 L10 15 L10 10 L20 10 L20 0 L30 0 L30 10 L25 10 L25 5 L35 5 L35 15 L40 15" fill="none" stroke="#6B1A1A" stroke-width="1.2"/>
        </pattern>
        <rect x="0" y="0" width="100%" height="22" fill="url(#meander)" opacity="0.12"/>
        <rect x="0" y="24" width="100%" height="1" fill="#6B1A1A" opacity="0.1"/>

        <!-- Bottom border -->
        <rect x="0" y="calc(100% - 24px)" width="100%" height="1" fill="#6B1A1A" opacity="0.1"/>
        <rect x="0" y="calc(100% - 22px)" width="100%" height="22" fill="url(#meander)" opacity="0.12"/>

        <!-- Left column -->
        <!-- Column shaft left -->
        <rect x="18" y="30" width="18" height="88%" fill="none" stroke="#6B1A1A" stroke-width="0.8" opacity="0.08"/>
        <!-- Fluting lines left column -->
        <line x1="22" y1="30" x2="22" y2="88%" stroke="#6B1A1A" stroke-width="0.5" opacity="0.06"/>
        <line x1="25" y1="30" x2="25" y2="88%" stroke="#6B1A1A" stroke-width="0.5" opacity="0.06"/>
        <line x1="28" y1="30" x2="28" y2="88%" stroke="#6B1A1A" stroke-width="0.5" opacity="0.06"/>
        <line x1="31" y1="30" x2="31" y2="88%" stroke="#6B1A1A" stroke-width="0.5" opacity="0.06"/>
        <!-- Capital left -->
        <path d="M8 52 Q27 42 46 52" fill="none" stroke="#6B1A1A" stroke-width="1" opacity="0.1"/>
        <path d="M4 44 Q27 30 50 44" fill="none" stroke="#6B1A1A" stroke-width="1" opacity="0.1"/>
        <!-- Ionic volute left -->
        <path d="M8 56 Q0 48 8 40 Q16 32 20 40 Q24 48 16 52" fill="none" stroke="#6B1A1A" stroke-width="0.8" opacity="0.08"/>
        <path d="M46 56 Q54 48 46 40 Q38 32 36 40 Q32 48 38 52" fill="none" stroke="#6B1A1A" stroke-width="0.8" opacity="0.08"/>

        <!-- Right column -->
        <rect x="calc(100% - 36px)" y="30" width="18" height="88%" fill="none" stroke="#6B1A1A" stroke-width="0.8" opacity="0.08"/>
        <line x1="calc(100% - 32px)" y1="30" x2="calc(100% - 32px)" y2="88%" stroke="#6B1A1A" stroke-width="0.5" opacity="0.06"/>
        <line x1="calc(100% - 29px)" y1="30" x2="calc(100% - 29px)" y2="88%" stroke="#6B1A1A" stroke-width="0.5" opacity="0.06"/>
        <line x1="calc(100% - 26px)" y1="30" x2="calc(100% - 26px)" y2="88%" stroke="#6B1A1A" stroke-width="0.5" opacity="0.06"/>
        <line x1="calc(100% - 23px)" y1="30" x2="calc(100% - 23px)" y2="88%" stroke="#6B1A1A" stroke-width="0.5" opacity="0.06"/>
        <!-- Capital right -->
        <path d="M calc(100% - 46px) 52 Q calc(100% - 27px) 42 calc(100% - 8px) 52" fill="none" stroke="#6B1A1A" stroke-width="1" opacity="0.1"/>
        <path d="M calc(100% - 50px) 44 Q calc(100% - 27px) 30 calc(100% - 4px) 44" fill="none" stroke="#6B1A1A" stroke-width="1" opacity="0.1"/>
        <!-- Ionic volute right -->
        <path d="M calc(100% - 8px) 56 Q calc(100% - 0px) 48 calc(100% - 8px) 40 Q calc(100% - 16px) 32 calc(100% - 20px) 40 Q calc(100% - 24px) 48 calc(100% - 16px) 52" fill="none" stroke="#6B1A1A" stroke-width="0.8" opacity="0.08"/>
        <path d="M calc(100% - 46px) 56 Q calc(100% - 54px) 48 calc(100% - 46px) 40 Q calc(100% - 38px) 32 calc(100% - 36px) 40 Q calc(100% - 32px) 48 calc(100% - 38px) 52" fill="none" stroke="#6B1A1A" stroke-width="0.8" opacity="0.08"/>

        <!-- Center top ornament -->
        <g opacity="0.09" transform="translate(50%, 28)">
          <path d="M-30 0 Q-20 -12 0 -8 Q20 -12 30 0 Q20 8 0 4 Q-20 8 -30 0Z" fill="none" stroke="#6B1A1A" stroke-width="1"/>
          <circle cx="0" cy="-2" r="4" fill="none" stroke="#6B1A1A" stroke-width="0.8"/>
          <line x1="-40" y1="0" x2="-30" y2="0" stroke="#6B1A1A" stroke-width="0.8"/>
          <line x1="30" y1="0" x2="40" y2="0" stroke="#6B1A1A" stroke-width="0.8"/>
        </g>
      </svg>
    </div>

    <nav>
      <a href="/" class="nav-logo">
        Felix Off Stage
        <span>Art & Theater</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/resources">Resources</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <span>© 2026 Felix Off Stage</span>
      <span>Essays on European Theater</span>
    </footer>
  </body>
</html>
